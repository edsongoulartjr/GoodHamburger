@page "/orders/new"
@page "/orders/{OrderId:guid}"
@using GoodHamburger.Web.Models
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>@(IsNew ? "Novo Pedido" : "Editar Pedido") — Good Hamburger</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <button class="btn btn-sm btn-outline-secondary" @onclick='() => Nav.NavigateTo("/orders")'>← Voltar</button>
    <h2 class="mb-0">@(IsNew ? "🆕 Novo Pedido" : "✏️ Editar Pedido")</h2>
</div>

@if (isLoading)
{
    <div class="gh-section">
        <p class="skeleton" style="width:55%">&nbsp;</p>
        <p class="skeleton mt-2" style="width:40%">&nbsp;</p>
        <p class="skeleton mt-2" style="width:70%">&nbsp;</p>
    </div>
}
else
{
    <div class="row g-3">
        <div class="col-lg-6">
            <div class="gh-section">
                <div class="gh-section-title">🛒 Selecione os itens</div>
                @foreach (var group in menuGroups)
                {
                    <p class="mb-1 mt-3" style="font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#6b7280">
                        @GroupLabel(group.Key)
                    </p>
                    @foreach (var item in group.Value)
                    {
                        <div class="form-check py-1">
                            <input class="form-check-input" type="checkbox"
                                   id="@item.Id"
                                   checked="@selectedIds.Contains(item.Id)"
                                   @onchange="e => ToggleItem(item.Id, (bool)e.Value!)" />
                            <label class="form-check-label d-flex justify-content-between" for="@item.Id">
                                <span>@item.Name</span>
                                <span class="price-value ms-2" style="color:#6b7280">R$&nbsp;@item.Price.ToString("F2")</span>
                            </label>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="gh-section">
                <div class="gh-section-title">📄 Resumo</div>
                @if (selectedItems.Any())
                {
                    <ul class="list-group list-group-flush mb-3">
                        @foreach (var item in selectedItems)
                        {
                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span>@item.Name</span>
                                <span class="price-value">R$&nbsp;@item.Price.ToString("F2")</span>
                            </li>
                        }
                    </ul>
                    <div class="d-flex justify-content-between py-1 border-top">
                        <span class="text-muted">Subtotal</span>
                        <span class="price-value">R$&nbsp;@Subtotal.ToString("F2")</span>
                    </div>
                    @if (DiscountPercent > 0)
                    {
                        <div class="d-flex justify-content-between py-1">
                            <span>
                                Desconto
                                <span class="discount-badge ms-1">@DiscountPercent%</span>
                            </span>
                            <span class="price-value" style="color:#065f46">- R$&nbsp;@Discount.ToString("F2")</span>
                        </div>
                    }
                    <div class="d-flex justify-content-between py-2 border-top mt-1">
                        <span class="fw-700">Total</span>
                        <span class="price-value price-total fw-bold">R$&nbsp;@Total.ToString("F2")</span>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <div style="font-size:2rem">🛒</div>
                        <p class="mb-0 mt-1">Nenhum item selecionado.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (errorMessage is not null)
    {
        <div class="alert alert-danger mt-2">@errorMessage</div>
    }

    <div class="mt-2 d-flex gap-2">
        <button class="btn btn-primary" @onclick="Submit" disabled="@(!selectedIds.Any())">
            @(IsNew ? "Criar Pedido" : "Salvar Alterações")
        </button>
        <button class="btn btn-outline-secondary" @onclick='() => Nav.NavigateTo("/orders")'>Cancelar</button>
    </div>
}

@code {
    [Parameter] public Guid? OrderId { get; set; }

    private bool IsNew => OrderId is null;
    private List<MenuItemModel> menuItems = [];
    private Dictionary<string, List<MenuItemModel>> menuGroups = [];
    private HashSet<Guid> selectedIds = [];
    private bool isLoading = true;
    private string? errorMessage;

    private IEnumerable<MenuItemModel> selectedItems => menuItems.Where(m => selectedIds.Contains(m.Id));
    private decimal Subtotal => selectedItems.Sum(i => i.Price);
    private decimal DiscountPercent => ComputeDiscount();
    private decimal Discount => Math.Round(Subtotal * DiscountPercent / 100, 2);
    private decimal Total => Subtotal - Discount;

    private decimal ComputeDiscount()
    {
        bool hasSandwich = selectedItems.Any(i => i.TypeDescription == "Sandwich");
        bool hasSide = selectedItems.Any(i => i.TypeDescription == "SideDish");
        bool hasBeverage = selectedItems.Any(i => i.TypeDescription == "Beverage");
        return (hasSandwich, hasSide, hasBeverage) switch
        {
            (true, true, true) => 20m,
            (true, false, true) => 15m,
            (true, true, false) => 10m,
            _ => 0m
        };
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            menuItems = await Http.GetFromJsonAsync<List<MenuItemModel>>("api/menu", ApiJsonOptions.Default) ?? [];
            menuGroups = menuItems.GroupBy(m => m.TypeDescription)
                .ToDictionary(g => g.Key, g => g.ToList());

            if (!IsNew)
            {
                var order = await Http.GetFromJsonAsync<OrderModel>($"api/orders/{OrderId}", ApiJsonOptions.Default);
                if (order is not null)
                    selectedIds = order.Items.Select(i => i.MenuItemId).ToHashSet();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleItem(Guid id, bool checked_)
    {
        if (checked_) selectedIds.Add(id);
        else selectedIds.Remove(id);
    }

    private static string GroupLabel(string type) => type switch
    {
        "Sandwich"  => "🥪 Sanduíches",
        "SideDish"  => "🍟 Acompanhamentos",
        "Beverage"  => "🥤 Bebidas",
        _           => type
    };

    private async Task Submit()
    {
        errorMessage = null;
        var request = new CreateOrderRequest { MenuItemIds = selectedIds.ToList() };

        try
        {
            HttpResponseMessage response;
            if (IsNew)
                response = await Http.PostAsJsonAsync("api/orders", request);
            else
                response = await Http.PutAsJsonAsync($"api/orders/{OrderId}", request);

            if (response.IsSuccessStatusCode)
            {
                Nav.NavigateTo("/orders");
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                Nav.NavigateTo("/login");
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                errorMessage = error?.Error ?? "Erro desconhecido.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private record ErrorResponse(string Error);
}
