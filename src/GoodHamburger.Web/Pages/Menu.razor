@page "/menu"
@using GoodHamburger.Web.Models
@inject HttpClient Http

<PageTitle>Cardápio — Good Hamburger</PageTitle>

<h2>🍔 Cardápio</h2>

@if (isLoading)
{
    <div class="gh-section">
        <p class="skeleton" style="width:40%">&nbsp;</p>
        <p class="skeleton mt-2" style="width:60%">&nbsp;</p>
        <p class="skeleton mt-2" style="width:50%">&nbsp;</p>
    </div>
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <div class="gh-section">
        <div class="gh-section-title">🥪 Sanduíches</div>
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Item</th>
                    <th class="col-price">Preço</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Sandwiches)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td class="col-price price-value">R$&nbsp;@item.Price.ToString("F2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="gh-section">
        <div class="gh-section-title">🍟 Acompanhamentos &amp; 🥤 Bebidas</div>
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Item</th>
                    <th class="col-price">Preço</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Others)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td class="col-price price-value">R$&nbsp;@item.Price.ToString("F2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="gh-discount-box">
        <strong>🎉 Descontos disponíveis</strong>
        <ul class="mb-0 mt-2" style="line-height:1.9">
            <li>🥪 + 🍟 + 🥤 → <strong>20% de desconto</strong></li>
            <li>🥪 + 🥤 → <strong>15% de desconto</strong></li>
            <li>🥪 + 🍟 → <strong>10% de desconto</strong></li>
        </ul>
    </div>
}

@code {
    private List<MenuItemModel> items = [];
    private bool isLoading = true;
    private string? errorMessage;

    private IEnumerable<MenuItemModel> Sandwiches =>
        items.Where(i => i.TypeDescription == "Sandwich");
    private IEnumerable<MenuItemModel> Others =>
        items.Where(i => i.TypeDescription != "Sandwich");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            items = await Http.GetFromJsonAsync<List<MenuItemModel>>("api/menu", ApiJsonOptions.Default) ?? [];
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar cardápio: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}

