@page "/orders"
@using GoodHamburger.Web.Models
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Pedidos — Good Hamburger</PageTitle>

<div class="d-flex align-items-center justify-content-between mb-3">
    <h2 class="mb-0">📋 Pedidos</h2>
    <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/orders/new")'>
        + Novo Pedido
    </button>
</div>

@if (isLoading)
{
    <div class="gh-section">
        <p class="skeleton" style="width:100%">&nbsp;</p>
        <p class="skeleton mt-2" style="width:100%">&nbsp;</p>
        <p class="skeleton mt-2" style="width:80%">&nbsp;</p>
    </div>
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (!orders.Any())
{
    <div class="gh-section text-center py-5 text-muted">
        <div style="font-size:2.5rem">🛒</div>
        <p class="mt-2 mb-3">Nenhum pedido encontrado.</p>
        <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/orders/new")'>Criar primeiro pedido</button>
    </div>
}
else
{
    <div class="gh-section p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Data</th>
                    <th>Itens</th>
                    <th class="col-price">Subtotal</th>
                    <th class="col-price">Desconto</th>
                    <th class="col-price">Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in orders)
                {
                    <tr>
                        <td><code style="font-size:.8rem;color:#6b7280">@order.Id.ToString()[..8]…</code></td>
                        <td style="white-space:nowrap;color:#6b7280;font-size:.85rem">
                            @order.CreatedAt.ToLocalTime().ToString("dd/MM/yy HH:mm")
                        </td>
                        <td style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                            @string.Join(", ", order.Items.Select(i => i.MenuItemName))
                        </td>
                        <td class="col-price price-value">R$&nbsp;@order.Subtotal.ToString("F2")</td>
                        <td class="col-price">
                            @if (order.DiscountPercentage > 0)
                            {
                                <span class="discount-badge">-@order.DiscountPercentage%</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="col-price price-value price-total">R$&nbsp;@order.Total.ToString("F2")</td>
                        <td style="white-space:nowrap">
                            <button class="btn btn-sm btn-outline-secondary me-1"
                                    title="Editar"
                                    @onclick='() => Nav.NavigateTo($"/orders/{order.Id}")'>✏️</button>
                            <button class="btn btn-sm btn-outline-danger"
                                    title="Excluir"
                                    @onclick="() => DeleteOrder(order.Id)">🗑️</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (successMessage is not null)
{
    <div class="alert alert-success mt-2">✅ @successMessage</div>
}

@code {
    private List<OrderModel> orders = [];
    private bool isLoading = true;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync() => await LoadOrders();

    private async Task LoadOrders()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var paged = await Http.GetFromJsonAsync<PagedResultModel<OrderModel>>("api/orders?page=1&pageSize=100", ApiJsonOptions.Default);
            orders = paged?.Items ?? [];
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Nav.NavigateTo("/login");
            return;
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar pedidos: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteOrder(Guid id)
    {
        var response = await Http.DeleteAsync($"api/orders/{id}");
        if (response.IsSuccessStatusCode)
        {
            successMessage = "Pedido removido com sucesso.";
            await LoadOrders();
        }
        else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Nav.NavigateTo("/login");
        }
        else
        {
            errorMessage = "Erro ao remover pedido.";
        }
    }
}
