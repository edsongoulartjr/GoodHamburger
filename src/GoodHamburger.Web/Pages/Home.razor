@page "/"

<PageTitle>Good Hamburger</PageTitle>

<div class="gh-hero">
    <h1>🍔 Good Hamburger</h1>
    <p class="mb-0">Sistema de pedidos da lanchonete. Rápido, simples e com desconto!</p>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body p-4">
                <div style="font-size:2rem">📋</div>
                <h5 class="card-title mt-2">Cardápio</h5>
                <p class="card-text text-muted">Veja todos os itens disponíveis com preços e descontos especiais.</p>
                <a href="menu" class="btn btn-primary">Ver Cardápio</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body p-4">
                <div style="font-size:2rem">🛒</div>
                <h5 class="card-title mt-2">Pedidos</h5>
                <p class="card-text text-muted">Crie, edite e gerencie os pedidos da lanchonete.</p>
                <a href="orders" class="btn btn-primary">Gerenciar Pedidos</a>
            </div>
        </div>
    </div>
</div>
