# Copie este arquivo para .env e preencha os valores antes de rodar o docker-compose.
# Nunca versione o arquivo .env com segredos reais.

# JWT — obrigatório, mínimo 32 caracteres
JWT_SECRET=troque-por-um-segredo-forte-aqui!!

# Senha do PostgreSQL (usado com --profile postgres)
POSTGRES_PASSWORD=troque-por-senha-forte

# Senha do SQL Server SA (usado com --profile sqlserver)
SQLSERVER_PASSWORD=Troque@SenhaForte1
